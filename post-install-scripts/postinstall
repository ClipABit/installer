#!/bin/bash
#
# ClipABit Plugin - macOS Postinstall Script
# Runs automatically when the .pkg is installed.
#
# Auth0 values are templated at build time by build-pkg.sh:
#   __AUTH0_DOMAIN__  __AUTH0_CLIENT_ID__  __AUTH0_AUDIENCE__  __ENVIRONMENT__
#

set -e

# -------------------------------------------------------------------
# Detect the real user (even when running as root via installer)
# -------------------------------------------------------------------
CURRENT_USER="${USER:-$(whoami)}"
if [ "$CURRENT_USER" = "root" ]; then
    CURRENT_USER=$(stat -f "%Su" /dev/console)
fi
USER_HOME=$(eval echo "~$CURRENT_USER")

echo "Running ClipABit Plugin Installer..."
echo "  User: $CURRENT_USER"
echo "  Home: $USER_HOME"

# -------------------------------------------------------------------
# Paths
# -------------------------------------------------------------------
STAGING_DIR="$2/ClipABit"

FUSION_BASE="$USER_HOME/Library/Application Support/Blackmagic Design/DaVinci Resolve/Fusion"
SCRIPTS_UTILITY="$FUSION_BASE/Scripts/Utility"
MODULES_DIR="$FUSION_BASE/Modules"
CONFIG_DIR="$USER_HOME/Library/Application Support/ClipABit"

PLUGIN_SOURCE="${STAGING_DIR}/plugin"

echo "  Staging: $STAGING_DIR"
echo "  Fusion:  $FUSION_BASE"

# -------------------------------------------------------------------
# Validate staging
# -------------------------------------------------------------------
if [ ! -f "${PLUGIN_SOURCE}/clipabit.py" ]; then
    echo "ERROR: Plugin shim not found at ${PLUGIN_SOURCE}/clipabit.py"
    exit 1
fi

# -------------------------------------------------------------------
# Create directories
# -------------------------------------------------------------------
echo "Creating directories..."
sudo -u "$CURRENT_USER" mkdir -p "$SCRIPTS_UTILITY"
sudo -u "$CURRENT_USER" mkdir -p "$MODULES_DIR"
sudo -u "$CURRENT_USER" mkdir -p "$CONFIG_DIR"

# -------------------------------------------------------------------
# Generate and install bootstrap shim
# -------------------------------------------------------------------
echo "Generating bootstrap shim..."

# Find python3
PYTHON_CMD="/usr/bin/python3"
if [ ! -x "$PYTHON_CMD" ]; then
    PYTHON_CMD=$(which python3 2>/dev/null || true)
fi
if [ -z "$PYTHON_CMD" ]; then
    echo "ERROR: python3 not found"
    exit 1
fi

# Use the installer script to generate the shim (it has the bootstrap preamble)
# We do this inline to avoid depending on the installer script at runtime.
SHIM_TARGET="$SCRIPTS_UTILITY/ClipABit.py"

sudo -u "$CURRENT_USER" "$PYTHON_CMD" -c "
import sys, os
obf_key = 'clipabit-resolve-plugin-2026'

preamble = '''# === ClipABit Installer Bootstrap ===
def _clipabit_bootstrap():
    import base64, json, os, sys
    _KEY = \"''' + obf_key + '''\"
    def _xor(data, key):
        kb = key.encode(\"utf-8\")
        return bytes(b ^ kb[i % len(kb)] for i, b in enumerate(data))
    config_locations = {
        \"darwin\": os.path.expanduser(
            \"~/Library/Application Support/ClipABit/config.dat\"),
        \"win32\": os.path.join(
            os.environ.get(\"APPDATA\", \"\"), \"ClipABit\", \"config.dat\"),
    }
    config_path = config_locations.get(
        sys.platform,
        os.path.expanduser(\"~/.config/clipabit/config.dat\"),
    )
    if os.path.exists(config_path):
        try:
            raw = open(config_path, \"r\").read().strip()
            cfg = json.loads(_xor(base64.b64decode(raw), _KEY).decode(\"utf-8\"))
            for k, v in cfg.items():
                os.environ.setdefault(k, str(v))
        except Exception:
            pass
    try:
        _sd = os.path.dirname(os.path.abspath(__file__))
    except NameError:
        _sd = os.getcwd()
    _deps = os.path.abspath(os.path.join(_sd, \"..\", \"..\", \"Modules\", \"clipabit_deps\"))
    if os.path.isdir(_deps) and _deps not in sys.path:
        sys.path.insert(0, _deps)
_clipabit_bootstrap()
del _clipabit_bootstrap
# === End Installer Bootstrap ===

'''

original = open('${PLUGIN_SOURCE}/clipabit.py', 'r').read()
with open('${SHIM_TARGET}', 'w') as f:
    f.write(preamble + original)
"

chmod 755 "$SHIM_TARGET"
chown "$CURRENT_USER:staff" "$SHIM_TARGET"
echo "  Shim installed: $SHIM_TARGET"

# -------------------------------------------------------------------
# Copy plugin package -> Modules/clipabit/
# -------------------------------------------------------------------
echo "Installing plugin package..."
rm -rf "$MODULES_DIR/clipabit"
sudo -u "$CURRENT_USER" cp -R "${PLUGIN_SOURCE}/clipabit" "$MODULES_DIR/clipabit"
chown -R "$CURRENT_USER:staff" "$MODULES_DIR/clipabit"
echo "  Package installed: $MODULES_DIR/clipabit"

# -------------------------------------------------------------------
# Copy assets -> Modules/assets/
# -------------------------------------------------------------------
if [ -d "${PLUGIN_SOURCE}/assets" ]; then
    echo "Installing assets..."
    rm -rf "$MODULES_DIR/assets"
    sudo -u "$CURRENT_USER" cp -R "${PLUGIN_SOURCE}/assets" "$MODULES_DIR/assets"
    chown -R "$CURRENT_USER:staff" "$MODULES_DIR/assets"
    echo "  Assets installed: $MODULES_DIR/assets"
fi

# -------------------------------------------------------------------
# Install Python dependencies -> Modules/clipabit_deps/
# -------------------------------------------------------------------
echo "Installing Python dependencies..."
DEPS_DIR="$MODULES_DIR/clipabit_deps"
sudo -u "$CURRENT_USER" mkdir -p "$DEPS_DIR"

# Read deps from pyproject.toml if available, else use defaults
DEPS_LIST=""
if [ -f "${PLUGIN_SOURCE}/pyproject.toml" ]; then
    DEPS_LIST=$(sudo -u "$CURRENT_USER" "$PYTHON_CMD" -c "
import tomllib
with open('${PLUGIN_SOURCE}/pyproject.toml', 'rb') as f:
    data = tomllib.load(f)
deps = data.get('project', {}).get('dependencies', [])
print(' '.join(deps))
" 2>/dev/null || true)
fi

if [ -z "$DEPS_LIST" ]; then
    DEPS_LIST="pyqt6>=6.10.0 requests>=2.31.0 watchdog>=3.0.0 auth0-python>=4.7.0 keyring>=24.0.0"
fi

for dep in $DEPS_LIST; do
    echo "  Installing $dep..."
    sudo -u "$CURRENT_USER" "$PYTHON_CMD" -m pip install \
        --target "$DEPS_DIR" \
        --no-user \
        --no-cache-dir \
        "$dep" 2>&1 | tail -1 || true
done
chown -R "$CURRENT_USER:staff" "$DEPS_DIR"
echo "  Dependencies installed: $DEPS_DIR"

# -------------------------------------------------------------------
# Write obfuscated config.dat
# -------------------------------------------------------------------
AUTH0_DOMAIN="__AUTH0_DOMAIN__"
AUTH0_CLIENT_ID="__AUTH0_CLIENT_ID__"
AUTH0_AUDIENCE="__AUTH0_AUDIENCE__"
ENVIRONMENT="__ENVIRONMENT__"

if [ "$AUTH0_DOMAIN" != "" ] && [ "$AUTH0_DOMAIN" != "__AUTH0_DOMAIN__" ]; then
    echo "Writing config.dat..."
    sudo -u "$CURRENT_USER" "$PYTHON_CMD" -c "
import json, base64, os

key = 'clipabit-resolve-plugin-2026'
config = {
    'CLIPABIT_AUTH0_DOMAIN': '${AUTH0_DOMAIN}',
    'CLIPABIT_AUTH0_CLIENT_ID': '${AUTH0_CLIENT_ID}',
    'CLIPABIT_AUTH0_AUDIENCE': '${AUTH0_AUDIENCE}',
    'CLIPABIT_ENVIRONMENT': '${ENVIRONMENT}',
}
raw = json.dumps(config).encode('utf-8')
kb = key.encode('utf-8')
xored = bytes(b ^ kb[i % len(kb)] for i, b in enumerate(raw))
encoded = base64.b64encode(xored).decode('ascii')

config_path = os.path.expanduser('~/Library/Application Support/ClipABit/config.dat')
os.makedirs(os.path.dirname(config_path), exist_ok=True)
with open(config_path, 'w') as f:
    f.write(encoded)
print('  Config written: ' + config_path)
"
else
    echo "  Auth0 values not baked in. Skipping config.dat."
fi

# -------------------------------------------------------------------
# Cleanup staging
# -------------------------------------------------------------------
echo "Cleaning up staging directory..."
rm -rf "$STAGING_DIR" 2>/dev/null || true

echo ""
echo "  ClipABit plugin installed successfully!"
echo "  Shim:    $SHIM_TARGET"
echo "  Package: $MODULES_DIR/clipabit"
echo "  Deps:    $DEPS_DIR"
echo "  Config:  $CONFIG_DIR/config.dat"
echo ""

exit 0
