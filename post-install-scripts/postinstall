#!/bin/bash
#
# ClipABit Plugin - macOS Postinstall Script
# Runs automatically when the .pkg is installed.
#
# Auth0 values are templated at build time by build-pkg.sh:
#   __AUTH0_DOMAIN__  __AUTH0_CLIENT_ID__  __AUTH0_AUDIENCE__  __ENVIRONMENT__
#

set -e

# -------------------------------------------------------------------
# Detect the real user (even when running as root via installer)
# -------------------------------------------------------------------
CURRENT_USER="${USER:-$(whoami)}"
if [ "$CURRENT_USER" = "root" ]; then
    CURRENT_USER=$(stat -f "%Su" /dev/console)
fi
USER_HOME=$(eval echo "~$CURRENT_USER")

echo "Running ClipABit Plugin Installer..."
echo "  User: $CURRENT_USER"
echo "  Home: $USER_HOME"

# -------------------------------------------------------------------
# Paths
# -------------------------------------------------------------------
STAGING_DIR="$2/ClipABit"

FUSION_BASE="$USER_HOME/Library/Application Support/Blackmagic Design/DaVinci Resolve/Fusion"
SCRIPTS_UTILITY="$FUSION_BASE/Scripts/Utility"
MODULES_DIR="$FUSION_BASE/Modules"
CLIPABIT_DIR="$USER_HOME/Library/Application Support/ClipABit"
CONFIG_DIR="$CLIPABIT_DIR"

PLUGIN_SOURCE="${STAGING_DIR}/plugin"
BUNDLED_PYTHON_SOURCE="${STAGING_DIR}/python"

echo "  Staging:    $STAGING_DIR"
echo "  Fusion:     $FUSION_BASE"
echo "  ClipABit:   $CLIPABIT_DIR"

# -------------------------------------------------------------------
# Check if DaVinci Resolve is running
# -------------------------------------------------------------------
if pgrep -x "DaVinci Resolve" >/dev/null 2>&1; then
    echo ""
    echo "ERROR: DaVinci Resolve is currently running."
    echo "Please quit DaVinci Resolve and re-run the installer."
    echo ""
    exit 1
fi

# -------------------------------------------------------------------
# Validate staging
# -------------------------------------------------------------------
if [ ! -f "${PLUGIN_SOURCE}/clipabit.py" ]; then
    echo "ERROR: Plugin shim not found at ${PLUGIN_SOURCE}/clipabit.py"
    exit 1
fi
if [ ! -f "${PLUGIN_SOURCE}/pyproject.toml" ]; then
    echo "ERROR: pyproject.toml not found at ${PLUGIN_SOURCE}/pyproject.toml"
    exit 1
fi
if [ ! -d "${PLUGIN_SOURCE}/clipabit" ]; then
    echo "ERROR: clipabit package not found at ${PLUGIN_SOURCE}/clipabit"
    exit 1
fi
if [ ! -d "${BUNDLED_PYTHON_SOURCE}" ]; then
    echo "ERROR: Bundled Python not found at ${BUNDLED_PYTHON_SOURCE}"
    echo "Installer package appears corrupt or incomplete."
    exit 1
fi

# -------------------------------------------------------------------
# Create directories
# -------------------------------------------------------------------
echo "Creating directories..."
sudo -u "$CURRENT_USER" mkdir -p "$SCRIPTS_UTILITY"
sudo -u "$CURRENT_USER" mkdir -p "$MODULES_DIR"
sudo -u "$CURRENT_USER" mkdir -p "$CLIPABIT_DIR"

# -------------------------------------------------------------------
# Backup existing installation
# -------------------------------------------------------------------
echo "Backing up existing ClipABit installation..."
backup_item() {
    local item="$1"
    local bak="${item}.bak"
    if [ -e "$bak" ]; then
        rm -rf "$bak"
    fi
    if [ -e "$item" ]; then
        mv "$item" "$bak"
    fi
}

backup_item "$SCRIPTS_UTILITY/ClipABit.py"
backup_item "$MODULES_DIR/clipabit"
backup_item "$CLIPABIT_DIR/python"
backup_item "$CLIPABIT_DIR/deps"
backup_item "$CONFIG_DIR/config.dat"

# Rollback function for failure recovery
do_rollback() {
    echo "Rolling back to previous installation..."
    local items=(
        "$SCRIPTS_UTILITY/ClipABit.py"
        "$MODULES_DIR/clipabit"
        "$CLIPABIT_DIR/python"
        "$CLIPABIT_DIR/deps"
        "$CONFIG_DIR/config.dat"
    )
    for item in "${items[@]}"; do
        local bak="${item}.bak"
        if [ -e "$item" ]; then
            rm -rf "$item"
        fi
        if [ -e "$bak" ]; then
            mv "$bak" "$item"
        fi
    done
}

# -------------------------------------------------------------------
# Install bundled Python runtime
# -------------------------------------------------------------------
echo "Installing ClipABit Python runtime..."
sudo -u "$CURRENT_USER" cp -R "${BUNDLED_PYTHON_SOURCE}" "$CLIPABIT_DIR/python"
chown -R "$CURRENT_USER:staff" "$CLIPABIT_DIR/python"

# Remove quarantine xattr (bundled Python is unsigned)
xattr -dr com.apple.quarantine "$CLIPABIT_DIR/python" 2>/dev/null || true

# Validate
PYTHON_CMD="$CLIPABIT_DIR/python/bin/python3"
if [ ! -x "$PYTHON_CMD" ]; then
    echo "ERROR: Bundled Python not found after copy"
    do_rollback
    exit 1
fi
PYTHON_REPORTED=$("$PYTHON_CMD" --version 2>&1 | awk '{print $2}')
if [[ ! "${PYTHON_REPORTED}" == 3.11.* ]]; then
    echo "ERROR: Bundled Python reports ${PYTHON_REPORTED}, expected 3.11.x"
    do_rollback
    exit 1
fi
echo "  Python: $PYTHON_REPORTED"

# Validate pip
if ! "$PYTHON_CMD" -m pip --version >/dev/null 2>&1; then
    echo "  pip not found, trying ensurepip..."
    "$PYTHON_CMD" -m ensurepip --default-pip || {
        echo "ERROR: Failed to install pip in bundled Python"
        do_rollback
        exit 1
    }
fi

# -------------------------------------------------------------------
# Install Python dependencies -> ~/Library/Application Support/ClipABit/deps/
# -------------------------------------------------------------------
echo "Installing ClipABit dependencies..."
DEPS_DIR="$CLIPABIT_DIR/deps"
sudo -u "$CURRENT_USER" mkdir -p "$DEPS_DIR"

# Read deps from pyproject.toml (one per line so PEP 508 markers are preserved)
DEPS_FILE=$(mktemp)
trap 'rm -f "$DEPS_FILE"' EXIT
if ! sudo -u "$CURRENT_USER" \
    _CLIPABIT_PLUGIN_SOURCE="$PLUGIN_SOURCE" \
    "$PYTHON_CMD" -c "
import os, tomllib
plugin_source = os.environ['_CLIPABIT_PLUGIN_SOURCE']
with open(os.path.join(plugin_source, 'pyproject.toml'), 'rb') as f:
    data = tomllib.load(f)
deps = data.get('project', {}).get('dependencies', [])
if not deps:
    raise SystemExit('No dependencies listed in pyproject.toml')
for d in deps:
    print(d)
" > "$DEPS_FILE"; then
    echo "ERROR: Failed to read dependencies from pyproject.toml"
    do_rollback
    exit 1
fi

FAILED_DEPS=""
while IFS= read -r dep || [ -n "$dep" ]; do
    [ -z "$dep" ] && continue
    echo "  Installing $dep..."
    if ! sudo -u "$CURRENT_USER" "$PYTHON_CMD" -m pip install \
        --target "$DEPS_DIR" \
        --only-binary=:all: \
        --no-user \
        --no-cache-dir \
        "$dep" 2>&1; then
        echo "  ERROR: Failed to install $dep"
        FAILED_DEPS="$FAILED_DEPS $dep"
    fi
done < "$DEPS_FILE"

if [ -n "$FAILED_DEPS" ]; then
    echo "ERROR: Failed to install dependencies:$FAILED_DEPS"
    do_rollback
    exit 1
fi

chown -R "$CURRENT_USER:staff" "$DEPS_DIR"
echo "  Dependencies installed: $DEPS_DIR"

# -------------------------------------------------------------------
# Copy plugin package -> Modules/clipabit/
# -------------------------------------------------------------------
echo "Installing ClipABit plugin files..."
sudo -u "$CURRENT_USER" cp -R "${PLUGIN_SOURCE}/clipabit" "$MODULES_DIR/clipabit"
chown -R "$CURRENT_USER:staff" "$MODULES_DIR/clipabit"

# Validate
if [ ! -f "$MODULES_DIR/clipabit/__init__.py" ]; then
    echo "ERROR: Plugin package missing __init__.py after copy"
    do_rollback
    exit 1
fi
echo "  Package installed: $MODULES_DIR/clipabit"

# -------------------------------------------------------------------
# Write obfuscated config.dat
# -------------------------------------------------------------------
echo "Configuring ClipABit..."

AUTH0_DOMAIN="__AUTH0_DOMAIN__"
AUTH0_CLIENT_ID="__AUTH0_CLIENT_ID__"
AUTH0_AUDIENCE="__AUTH0_AUDIENCE__"
ENVIRONMENT="__ENVIRONMENT__"

if [ "$AUTH0_DOMAIN" != "" ] && [ "$AUTH0_DOMAIN" != "__AUTH0_DOMAIN__" ]; then
    if [ "$AUTH0_CLIENT_ID" = "__AUTH0_CLIENT_ID__" ] || [ "$AUTH0_AUDIENCE" = "__AUTH0_AUDIENCE__" ]; then
        echo "ERROR: Auth0 config partially templated. Domain set but client_id or audience missing."
        do_rollback
        exit 1
    fi
    # Pass Auth0 values via env to avoid injection (no quotes/backslashes in Python source)
    sudo -u "$CURRENT_USER" \
        CLIPABIT_AUTH0_DOMAIN="$AUTH0_DOMAIN" \
        CLIPABIT_AUTH0_CLIENT_ID="$AUTH0_CLIENT_ID" \
        CLIPABIT_AUTH0_AUDIENCE="$AUTH0_AUDIENCE" \
        CLIPABIT_ENVIRONMENT="$ENVIRONMENT" \
        "$PYTHON_CMD" -c "
import json, base64, os
key = 'clipabit-resolve-plugin-2026'
config = {
    'CLIPABIT_AUTH0_DOMAIN': os.environ.get('CLIPABIT_AUTH0_DOMAIN', ''),
    'CLIPABIT_AUTH0_CLIENT_ID': os.environ.get('CLIPABIT_AUTH0_CLIENT_ID', ''),
    'CLIPABIT_AUTH0_AUDIENCE': os.environ.get('CLIPABIT_AUTH0_AUDIENCE', ''),
    'CLIPABIT_ENVIRONMENT': os.environ.get('CLIPABIT_ENVIRONMENT', 'prod'),
}
raw = json.dumps(config).encode('utf-8')
kb = key.encode('utf-8')
xored = bytes(b ^ kb[i % len(kb)] for i, b in enumerate(raw))
encoded = base64.b64encode(xored).decode('ascii')
config_path = os.path.expanduser('~/Library/Application Support/ClipABit/config.dat')
os.makedirs(os.path.dirname(config_path), exist_ok=True)
with open(config_path, 'w') as f:
    f.write(encoded)
print('  Config written: ' + config_path)
"
else
    echo "  Auth0 values not baked in. Skipping config.dat."
fi

# -------------------------------------------------------------------
# Generate and install bootstrap shim (LAST — so partial installs
# don't show a broken entry in Resolve's Scripts menu)
# -------------------------------------------------------------------
echo "Finalizing ClipABit installation..."

SHIM_TARGET="$SCRIPTS_UTILITY/ClipABit.py"

sudo -u "$CURRENT_USER" \
    _CLIPABIT_PLUGIN_SOURCE="$PLUGIN_SOURCE" \
    _CLIPABIT_SHIM_TARGET="$SHIM_TARGET" \
    "$PYTHON_CMD" -c "
import sys, os
obf_key = 'clipabit-resolve-plugin-2026'
plugin_source = os.environ['_CLIPABIT_PLUGIN_SOURCE']
shim_target = os.environ['_CLIPABIT_SHIM_TARGET']

preamble = '''# === ClipABit Installer Bootstrap ===
def _clipabit_bootstrap():
    import base64, json, os, sys
    _KEY = \"''' + obf_key + '''\"
    def _xor(data, key):
        kb = key.encode(\"utf-8\")
        return bytes(b ^ kb[i % len(kb)] for i, b in enumerate(data))
    config_locations = {
        \"darwin\": os.path.expanduser(
            \"~/Library/Application Support/ClipABit/config.dat\"),
        \"win32\": os.path.join(
            os.environ.get(\"APPDATA\", \"\"), \"ClipABit\", \"config.dat\"),
    }
    config_path = config_locations.get(
        sys.platform,
        os.path.expanduser(\"~/.config/clipabit/config.dat\"),
    )
    if os.path.exists(config_path):
        try:
            raw = open(config_path, \"r\").read().strip()
            cfg = json.loads(_xor(base64.b64decode(raw), _KEY).decode(\"utf-8\"))
            for k, v in cfg.items():
                os.environ.setdefault(k, str(v))
        except Exception:
            pass
    _deps_locations = {
        \"darwin\": os.path.expanduser(
            \"~/Library/Application Support/ClipABit/deps\"),
        \"win32\": os.path.join(
            os.environ.get(\"LOCALAPPDATA\", \"\"), \"ClipABit\", \"deps\"),
    }
    _deps = _deps_locations.get(sys.platform, \"\")
    if os.path.isdir(_deps) and _deps not in sys.path:
        sys.path.insert(0, _deps)
_clipabit_bootstrap()
del _clipabit_bootstrap
# === End Installer Bootstrap ===

'''

original = open(os.path.join(plugin_source, 'clipabit.py'), 'r').read()
shim = preamble + original

# Validate syntax before writing
compile(shim, 'ClipABit.py', 'exec')

with open(shim_target, 'w') as f:
    f.write(shim)
"

if [ $? -ne 0 ]; then
    echo "ERROR: Failed to generate bootstrap shim"
    do_rollback
    exit 1
fi

chmod 755 "$SHIM_TARGET"
chown "$CURRENT_USER:staff" "$SHIM_TARGET"
echo "  Shim installed: $SHIM_TARGET"

# -------------------------------------------------------------------
# Cleanup backups (success)
# -------------------------------------------------------------------
echo "Cleaning up backups..."
rm -f "$SCRIPTS_UTILITY/ClipABit.py.bak"
rm -rf "$MODULES_DIR/clipabit.bak"
rm -rf "$CLIPABIT_DIR/python.bak"
rm -rf "$CLIPABIT_DIR/deps.bak"
rm -f "$CONFIG_DIR/config.dat.bak"

# -------------------------------------------------------------------
# Cleanup staging
# -------------------------------------------------------------------
echo "Cleaning up staging directory..."
rm -rf "$STAGING_DIR" 2>/dev/null || true

echo ""
echo "=========================================="
echo "  ClipABit Installation Complete!"
echo "=========================================="
echo ""
echo "  ClipABit has been installed successfully."
echo ""
echo "  To access ClipABit in DaVinci Resolve:"
echo "    1. Open DaVinci Resolve"
echo "    2. Go to Workspace > Scripts > ClipABit"
echo ""
echo "  Installation Details:"
echo "    Shim:    $SHIM_TARGET"
echo "    Package: $MODULES_DIR/clipabit"
echo "    Python:  $CLIPABIT_DIR/python"
echo "    Deps:    $DEPS_DIR"
echo "    Config:  $CONFIG_DIR/config.dat"
echo ""

exit 0
